# ─────────────────────────────────────────────────────────────────────────────
# SigmaCV environment. Copy to `.env` and fill in. NEVER commit `.env`.
# All variables are validated at startup by src/lib/env.ts.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# Local (docker compose service name is `postgres`):
DATABASE_URL="postgresql://sigmacv:sigmacv@localhost:5432/sigmacv?schema=public"

# Auth.js — generate a secret with: openssl rand -base64 33
AUTH_SECRET="change-me-generate-a-random-secret"
# Public base URL of the app (used for OAuth callbacks).
AUTH_URL="http://localhost:3000"

# ── ORCID OAuth (OpenID Connect) ────────────────────────────────────────────
# Register a *public API* client:
#   sandbox:    https://sandbox.orcid.org/developer-tools
#   production: https://orcid.org/developer-tools
# Redirect URI to register: {AUTH_URL}/api/auth/callback/orcid
ORCID_CLIENT_ID="APP-XXXXXXXXXXXXXXXX"
ORCID_CLIENT_SECRET="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# "sandbox" (default, for dev) or "production".
ORCID_ENVIRONMENT="sandbox"

# ── OpenAlex / Crossref polite pool ──────────────────────────────────────────
# A contact email sent as `mailto=` on OpenAlex AND Crossref requests (joins
# their polite pools — faster, kinder). Use a project/admin address, not a
# personal one. (ROR needs no contact and is called without it.)
OPENALEX_MAILTO="hello@example.org"

# ── Optional alternate logins (leave blank to disable) ───────────────────────
# Google OAuth (redirect URI: {AUTH_URL}/api/auth/callback/google)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Email magic-link sign-in (passwordless). Needs an SMTP server.
#   EMAIL_SERVER="smtp://user:password@smtp.example.org:587"
#   EMAIL_FROM="SigmaCV <no-reply@example.org>"
EMAIL_SERVER=""
EMAIL_FROM=""

# ── Open Editors Plus (editorial roles) ──────────────────────────────────────
# URL to a JSON dataset: [{ "orcid","journal","role","startYear","endYear" }].
# Leave blank to disable the editorial-roles section.
OEP_DATA_URL=""

# ── Scheduled public re-sync ─────────────────────────────────────────────────
# Shared secret guarding POST /api/internal/resync (the cron container's target).
# Generate: openssl rand -base64 33. Leave blank to disable the feature.
RESYNC_SECRET=""
RESYNC_INTERVAL_SECONDS="3600"

# ── Support / donations (optional) ───────────────────────────────────────────
# A "Buy me a coffee" link shown in the editor + landing page chrome (NOT on
# users' CVs). Public (NEXT_PUBLIC_*) — inlined into the client bundle. Leave
# blank to hide the button. Example: https://www.buymeacoffee.com/yourname
NEXT_PUBLIC_BUYMEACOFFEE_URL=""
