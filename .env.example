# ─────────────────────────────────────────────────────────────────────────────
# SigmaCV environment. Copy to `.env` and fill in. NEVER commit `.env`.
# All variables are validated at startup by src/lib/env.ts.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# Local (docker compose service name is `postgres`):
DATABASE_URL="postgresql://sigmacv:sigmacv@localhost:5432/sigmacv?schema=public"

# Auth.js — generate a secret with: openssl rand -base64 33
AUTH_SECRET="change-me-generate-a-random-secret"
# Public base URL of the app (used for OAuth callbacks).
AUTH_URL="http://localhost:3000"

# ── ORCID OAuth (OpenID Connect) ────────────────────────────────────────────
# Register a *public API* client:
#   sandbox:    https://sandbox.orcid.org/developer-tools
#   production: https://orcid.org/developer-tools
# Redirect URI to register: {AUTH_URL}/api/auth/callback/orcid
ORCID_CLIENT_ID="APP-XXXXXXXXXXXXXXXX"
ORCID_CLIENT_SECRET="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# "sandbox" (default, for dev) or "production".
ORCID_ENVIRONMENT="sandbox"

# ── OpenAlex / Crossref polite pool ──────────────────────────────────────────
# A contact email sent as `mailto=` on OpenAlex AND Crossref requests (joins
# their polite pools — faster, kinder). Use a project/admin address, not a
# personal one. (ROR needs no contact and is called without it.)
OPENALEX_MAILTO="hello@example.org"

# ── Optional alternate logins (leave blank to disable) ───────────────────────
# Google OAuth (redirect URI: {AUTH_URL}/api/auth/callback/google)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Email magic-link sign-in (passwordless). Needs an SMTP server.
#   EMAIL_SERVER="smtp://user:password@smtp.example.org:587"
#   EMAIL_FROM="SigmaCV <no-reply@example.org>"
EMAIL_SERVER=""
EMAIL_FROM=""

# ── Open Editors Plus (editorial roles) ──────────────────────────────────────
# URL to a JSON dataset: [{ "orcid","journal","role","startYear","endYear" }].
# Leave blank to disable the editorial-roles section.
OEP_DATA_URL=""

# ── Scheduled public re-sync ─────────────────────────────────────────────────
# Shared secret guarding POST /api/internal/resync (the cron container's target).
# Generate: openssl rand -base64 33. Leave blank to disable the feature.
RESYNC_SECRET=""
RESYNC_INTERVAL_SECONDS="3600"

# ── Research logging (papers #2/#3) ──────────────────────────────────────────
# Master switch for the consent-gated research-logging programme. OFF unless set
# to exactly "true". Leave unset/blank until an IRB / ethics protocol is in place:
# while off, NO ResearchEvent rows are written and the consent prompt is hidden.
RESEARCH_LOGGING_ENABLED=""

# ── Researcher data export (papers #2/#3) — IRB-GATED, OFF by default ─────────
# The OFFLINE `npm run research:export` refuses to run unless ALL THREE below are
# set. Leave them unset until the IRB protocol is APPROVED and the export fields
# are finalised to match the pre-registration. The export pseudonymises subjects
# (keyed HMAC) and emits only pre-registered event types — never names / emails /
# ORCIDs. There is no network route; it reads the DB directly. See
# src/lib/research/export.ts and scripts/export-research-data.ts.
RESEARCH_EXPORT_ENABLED=""
# The IRB approval number — recorded in the output filename for the audit trail.
RESEARCH_EXPORT_IRB_REF=""
# Secret pseudonymisation salt (>=16 chars). Keep it stable for longitudinal
# linkage and confidential — it is the only thing that could re-identify subjects.
RESEARCH_EXPORT_PSEUDONYM_SALT=""

# ── OpenAlex upstream curation push (Phase 5 — give back to the commons) ──────
# DEFERRED v2, OFF by default. When unset/blank the app makes NO external
# curation write — ever: POST /api/cv/assert returns 503 and the write-client
# short-circuits to "disabled" without touching the network. The real OpenAlex
# curation API contract is UNCONFIRMED, so the payload + endpoint are PROVISIONAL.
# Set to exactly "true" only once the endpoint below is verified against the real
# API. Leave the endpoint blank and the push fails closed (reports an error,
# never guesses a URL).
OPENALEX_CURATION_ENABLED=""
OPENALEX_CURATION_ENDPOINT=""

# ── Public site URL (SEO) ────────────────────────────────────────────────────
# Canonical production origin, used for canonical URLs, hreflang, sitemap,
# robots, Open Graph and JSON-LD. Set this to your real domain in production.
# Inlined at build time (NEXT_PUBLIC_*). Falls back to https://sigmacv.org.
NEXT_PUBLIC_SITE_URL="https://sigmacv.org"

# ── Site / creator links (optional) ──────────────────────────────────────────
# Links shown in the editor + landing/About chrome (NEVER on users' CVs).
# Public (NEXT_PUBLIC_*) — inlined into the client bundle. Leave blank to hide.
#   Buy me a coffee, e.g. https://buymeacoffee.com/yourname
NEXT_PUBLIC_BUYMEACOFFEE_URL=""
#   The open-source repository
NEXT_PUBLIC_GITHUB_URL=""
#   Your LinkedIn profile
NEXT_PUBLIC_LINKEDIN_URL=""
