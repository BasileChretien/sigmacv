# SigmaCV — PRODUCTION environment template.
#
# On the server: copy this to `.env` (NOT committed) and fill in real values.
#     cp .env.production.example .env  &&  nano .env
# docker-compose.prod.yml reads these via ${VAR} substitution.

# ── Database (managed Postgres, e.g. Neon) ───────────────────────────────────
# Use the DIRECT (non-pooler) endpoint. Prefer ?sslmode=verify-full for full TLS
# certificate + hostname verification (Neon supports it; its certs chain to a
# public CA in Node's trust store). Avoid a bare ?sslmode=require: node-postgres
# v9 / pg-connection-string v3 will weaken it to encrypt-only (no cert check) and
# the current driver already warns about it. The Prisma 7 pg adapter connects
# over TLS either way.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.eu-central-1.aws.neon.tech/neondb?sslmode=verify-full"

# ── Auth.js ──────────────────────────────────────────────────────────────────
# Generate a fresh secret:  openssl rand -base64 33
AUTH_SECRET="REPLACE_WITH_openssl_rand_base64_33"
# Canonical public origin. MUST equal the scheme+host you serve on AND match the
# host of the ORCID redirect URI. No trailing slash.
AUTH_URL="https://cv.example.org"

# ── Caddy / TLS ──────────────────────────────────────────────────────────────
# Your domain → automatic Let's Encrypt TLS. Must resolve (A/AAAA) to this server.
# Use ":80" ONLY for throwaway IP/HTTP testing (ORCID login won't work then).
SITE_ADDRESS="cv.example.org"

# ── ORCID OAuth (production app at https://orcid.org/developer-tools) ─────────
# The app's redirect URI MUST be exactly:  ${AUTH_URL}/api/auth/callback/orcid
ORCID_CLIENT_ID="APP-XXXXXXXXXXXXXXXX"
ORCID_CLIENT_SECRET="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
ORCID_ENVIRONMENT="production"

# ── OpenAlex polite pool ─────────────────────────────────────────────────────
OPENALEX_MAILTO="you@example.org"

# ── Rate limiting ────────────────────────────────────────────────────────────
# Use the Postgres-backed (durable, cross-instance) rate limiter instead of the
# per-process in-memory one. RECOMMENDED in production so per-user limits survive
# restarts/redeploys and hold if the app is ever scaled to multiple instances.
RATE_LIMIT_PERSIST="true"

# ── Living-CV scheduled re-sync (optional) ───────────────────────────────────
# Set a >=16-char secret to enable the internal /api/internal/resync endpoint
# + the resync-cron service. Leave blank to disable (endpoint returns 503).
RESYNC_SECRET=""
RESYNC_INTERVAL_SECONDS="3600"

# ── OpenAlex upstream curation push (Phase 5) — DEFERRED v2, OFF ─────────────
# Leave BOTH blank in production until the OpenAlex curation API contract is
# confirmed. While unset, POST /api/cv/assert returns 503 and no external
# curation write is ever made. Do NOT enable without verifying the (provisional)
# payload + endpoint against the real API.
OPENALEX_CURATION_ENABLED=""
OPENALEX_CURATION_ENDPOINT=""

# ── Optional alternate logins / data (leave blank to disable) ────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# SMTP also powers the OPT-IN re-sync digest emails (account toggle; one-click
# unsubscribe). Leave blank to keep email login + digests dormant.
# Free, no-branding setup (SMTP2GO + Porkbun DNS): see docs/EMAIL-SETUP.md.
# e.g. EMAIL_SERVER="smtp://USER:PASS@mail.smtp2go.com:2525" (URL-encode specials)
EMAIL_SERVER=""
EMAIL_FROM=""
# OpenAIRE Graph API refresh token (optional; higher rate limits). REFRESH token only.
OPENAIRE_REFRESH_TOKEN=""
# EPO Open Patent Services (optional; patents by inventor). OAuth key+secret from
# a free OPS app at https://developers.epo.org. Dormant when unset.
EPO_OPS_KEY=""
EPO_OPS_SECRET=""

# ── Site-owner links / public config (NEXT_PUBLIC_*) ─────────────────────────
# INLINED INTO THE CLIENT BUNDLE AT BUILD TIME — compose passes these as
# `build.args`, so you must `docker compose up -d --build` (not just `up -d`)
# after changing them. Leave blank to omit the link. NEXT_PUBLIC_SITE_URL falls
# back to https://sigmacv.org in code when blank.
NEXT_PUBLIC_SITE_URL="https://sigmacv.org"
# "Buy me a coffee" / Ko-fi support link shown in the editor + landing chrome.
NEXT_PUBLIC_BUYMEACOFFEE_URL=""
NEXT_PUBLIC_GITHUB_URL=""
NEXT_PUBLIC_LINKEDIN_URL=""

# ── Analytics (OPTIONAL — cookieless, first-party, self-hosted) ──────────────
# Enabled only when you start the `analytics` compose profile:
#     docker compose --profile analytics up -d --build
# A plain `docker compose up -d` ignores all of this. Full runbook + the
# read-only DB role steps are in docs/ANALYTICS.md. Leave this whole block unset
# if you don't run analytics.
#
# Generate secrets and pipe through `tr -d '\n'` so they stay on ONE line, e.g.:
#   openssl rand -base64 48 | tr -d '\n'   -> PLAUSIBLE_SECRET_KEY_BASE (>= 64 chars)
#   openssl rand -base64 32 | tr -d '\n'   -> PLAUSIBLE_TOTP_VAULT_KEY (REQUIRED; decodes to 32 bytes)
#   openssl rand -hex 24                   -> the DB passwords (HEX, not base64:
#       PLAUSIBLE_DB_PASSWORD is embedded in a postgres:// URL, where base64's
#       +/= characters break authentication)
# (`openssl rand -base64 64` wraps onto two lines — hence the tr; don't paste a wrapped value.)
#
# -- Plausible (traffic) --
# Public URL of the Plausible instance (its own subdomain, gets auto-TLS):
PLAUSIBLE_BASE_URL="https://plausible.sigmacv.org"
PLAUSIBLE_ADDRESS="plausible.sigmacv.org"          # Caddy site address (DNS A-record required)
PLAUSIBLE_SECRET_KEY_BASE="REPLACE_WITH_openssl_rand_base64_48"
# REQUIRED — Plausible v3 refuses to boot if this is blank. Must be exactly
# `openssl rand -base64 32` (a Base64-encoded 32 bytes; hex will NOT work here).
PLAUSIBLE_TOTP_VAULT_KEY="REPLACE_WITH_openssl_rand_base64_32"
PLAUSIBLE_DB_PASSWORD="REPLACE_WITH_openssl_rand_hex_24" # hex (URL-embedded); never leave a default
# Keep "false" ONLY for first-run sign-up, then set "true" and redeploy so the
# public Plausible instance can't be registered to by strangers.
PLAUSIBLE_DISABLE_REGISTRATION="false"
# Client tracking tag (INLINED at build time → rebuild after changing). Plausible
# CE v3 gives you a PER-SITE script — copy its exact URL from the dashboard
# (Site Settings → Installation), e.g. .../js/pa-<id>.js. The site is baked into
# that script, so DOMAIN is no longer used (kept here only for back-compat).
NEXT_PUBLIC_PLAUSIBLE_SRC="https://plausible.sigmacv.org/js/pa-REPLACE_WITH_YOUR_SITE_ID.js"
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
#
# -- Metabase (dashboards over the SigmaCV DB via the read-only role) --
ADMIN_ADDRESS="admin.sigmacv.org"                    # Caddy site address (DNS A-record required)
METABASE_SITE_URL="https://admin.sigmacv.org"
METABASE_DB_PASSWORD="REPLACE_WITH_openssl_rand_hex_24"     # Metabase's own config DB
