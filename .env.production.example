# SigmaCV — PRODUCTION environment template.
#
# On the server: copy this to `.env` (NOT committed) and fill in real values.
#     cp .env.production.example .env  &&  nano .env
# docker-compose.prod.yml reads these via ${VAR} substitution.

# ── Database (managed Postgres, e.g. Neon) ───────────────────────────────────
# Use the DIRECT (non-pooler) endpoint and keep ?sslmode=require. The Prisma 7
# pg driver adapter connects over TLS.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# ── Auth.js ──────────────────────────────────────────────────────────────────
# Generate a fresh secret:  openssl rand -base64 33
AUTH_SECRET="REPLACE_WITH_openssl_rand_base64_33"
# Canonical public origin. MUST equal the scheme+host you serve on AND match the
# host of the ORCID redirect URI. No trailing slash.
AUTH_URL="https://cv.example.org"

# ── Caddy / TLS ──────────────────────────────────────────────────────────────
# Your domain → automatic Let's Encrypt TLS. Must resolve (A/AAAA) to this server.
# Use ":80" ONLY for throwaway IP/HTTP testing (ORCID login won't work then).
SITE_ADDRESS="cv.example.org"

# ── ORCID OAuth (production app at https://orcid.org/developer-tools) ─────────
# The app's redirect URI MUST be exactly:  ${AUTH_URL}/api/auth/callback/orcid
ORCID_CLIENT_ID="APP-XXXXXXXXXXXXXXXX"
ORCID_CLIENT_SECRET="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
ORCID_ENVIRONMENT="production"

# ── OpenAlex polite pool ─────────────────────────────────────────────────────
OPENALEX_MAILTO="you@example.org"

# ── Rate limiting ────────────────────────────────────────────────────────────
# Use the Postgres-backed (durable, cross-instance) rate limiter instead of the
# per-process in-memory one. RECOMMENDED in production so per-user limits survive
# restarts/redeploys and hold if the app is ever scaled to multiple instances.
RATE_LIMIT_PERSIST="true"

# ── Living-CV scheduled re-sync (optional) ───────────────────────────────────
# Set a >=16-char secret to enable the internal /api/internal/resync endpoint
# + the resync-cron service. Leave blank to disable (endpoint returns 503).
RESYNC_SECRET=""
RESYNC_INTERVAL_SECONDS="3600"

# ── Optional alternate logins / data (leave blank to disable) ────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
EMAIL_SERVER=""
EMAIL_FROM=""
OEP_DATA_URL=""
