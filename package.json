{
  "name": "sigmacv",
  "version": "0.1.0",
  "private": true,
  "description": "Auto-generate clean, customizable academic CVs from open research data (OpenAlex, ORCID).",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/ensure-db.mjs",
    "dev": "next dev",
    "predev:public": "node scripts/ensure-db.mjs",
    "dev:public": "next dev -H ::",
    "db:sync": "node scripts/ensure-db.mjs",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "fetch-csl": "node scripts/fetch-csl.mjs",
    "resync": "node scripts/resync.mjs",
    "research:export": "dotenv -e .env -- tsx scripts/export-research-data.ts",
    "oep:import": "dotenv -e .env -- tsx scripts/oep-import.ts",
    "ictrp:import": "dotenv -e .env -- tsx scripts/ictrp-import.ts",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e .env -- prisma migrate dev",
    "db:push": "dotenv -e .env -- prisma db push",
    "db:push:e2e": "dotenv -e .env.e2e -- prisma db push",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install --with-deps chromium",
    "postinstall": "prisma generate",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,css,json,md,yml,yaml}": "prettier --write"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "nodemailer": "^8.0.10",
    "@hono/node-server": "^1.19.14"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "citeproc": "^2.4.63",
    "docx": "^9.0.0",
    "fast-xml-parser": "^4.5.6",
    "motion": "^12.40.0",
    "next": "^15.1.6",
    "next-auth": "^5.0.0-beta.25",
    "nodemailer": "^8.0.10",
    "pg": "^8.13.1",
    "playwright": "1.60.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.8",
    "dotenv": "^16.4.7",
    "dotenv-cli": "^8.0.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
