// SigmaCV database schema.
// Auth.js (NextAuth) standard models + SigmaCV-specific fields and the Cv row
// that stores the canonical CV object as JSON.

generator client {
  // Prisma 7: the Rust-free `prisma-client` generator (replaces prisma-client-js).
  // It emits TypeScript into `output`; we import from there, not "@prisma/client".
  // No binaryTargets — the v7 client uses a driver adapter (no Rust query engine).
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  // Prisma 7: the connection URL lives in prisma.config.ts (for the CLI) and is
  // supplied to the runtime client via the driver adapter (src/lib/db.ts).
  provider = "postgresql"
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  emailVerified   DateTime?
  image           String?
  // Bare ORCID iD (e.g. 0000-0002-7483-2489), set from the OIDC `sub` claim.
  orcid           String?   @unique
  // Structural research-consent hook. NO logging happens unless/until built.
  researchConsent Boolean   @default(false)
  // When consent was last granted, and the version of the consent notice the
  // user agreed to — needed for an IRB-defensible audit trail (what each user
  // agreed to, and when). Null until they first opt in.
  researchConsentAt      DateTime?
  researchConsentVersion Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  cv             Cv?
  researchEvents ResearchEvent[]
}

// Consent-gated research log (author-disambiguation + self-presentation studies).
// NOTHING is written here unless User.researchConsent is true. Cascade-deleted
// with the user; exportable via the account data-export endpoint.
model ResearchEvent {
  id        String   @id @default(cuid())
  userId    String
  // "curation_correction" (a mine/not-mine flip) | "composition_snapshot"
  type      String
  payload   Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  // Auth.js resolves a provider account by userId on sign-in, and the cascade
  // delete filters by it — index so neither is a sequential scan as users grow.
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Sessions are listed/cascade-deleted by userId (the data-export + account
  // deletion paths); index so those don't scan the whole session table.
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// One canonical CV document per user (the single source of truth).
model Cv {
  id            String    @id @default(cuid())
  userId        String    @unique
  document      Json
  schemaVersion Int       @default(1)
  lastSyncedAt  DateTime?
  // "What changed" report of the last sync (added/removed items, review
  // candidates, per-source counts + timings) — shown in the editor. Validated
  // on read by SyncReportSchema; a corrupt value degrades to "no report".
  lastSyncReport Json?
  // Living public page: published flag + a stable public slug.
  published     Boolean   @default(false)
  publicSlug    String?   @unique
  // Separate, explicit opt-in to let search engines index the public page.
  // Default false: publishing shares a capability URL; INDEXING (names/ORCID/
  // publications into Google) requires this distinct consent (GDPR/APPI).
  publicIndexable Boolean @default(false)
  // Compare-and-set lock for the scheduled re-sync job (null = unlocked).
  resyncLockedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([published, lastSyncedAt])
}

// Persistent fixed-window rate-limit counters. Used ONLY when the app runs as
// multiple instances and RATE_LIMIT_PERSIST=true (a single instance uses the
// in-memory limiter). One row per limiter key; `resetAt` bounds the window.
model RateLimitWindow {
  key     String   @id
  count   Int
  resetAt DateTime

  @@index([resetAt])
}

// Open Editors Plus reference data: journal editorial roles keyed by researcher
// ORCID. Bulk-imported from the committed OEP seed (`npm run oep:import`, see
// scripts/oep-import.ts) — ~347k rows, queried by `orcid` at CV-sync time to
// populate the Editorial Roles section. This is STATIC reference data, not user
// data: no relation to User, replaced wholesale on each import. Empty table =
// the integration is simply a no-op (no editorial section), so the app runs
// without it.
model OepEditorialRole {
  id        Int     @id @default(autoincrement())
  orcid     String
  journal   String
  role      String
  roleStd   String?
  publisher String?
  issn      String?

  @@index([orcid])
}

// WHO ICTRP reference data: clinical trials from the ~17 national registries
// (ISRCTN, jRCT, ChiCTR, CTRI, ANZCTR, …) that ClinicalTrials.gov and EU CTIS do
// NOT cover. DORMANT by default — there is NO committed seed (WHO's terms forbid
// redistribution and require a weekly refresh). The maintainer downloads the free
// WHO ICTRP weekly export, converts it to NDJSON and runs `npm run ictrp:import`
// (see scripts/ictrp-import.ts), which also drops any CT.gov / EU-CTR / CTIS rows
// to avoid double-listing trials already pulled directly. Empty table = no-op.
// Queried by contact surname at CV-sync time, then name+org matched in-app.
// ICTRP has no ORCID and only "contact" (not PI) names, so hits are review
// candidates. Static reference data — no relation to User; replaced on import.
model IctrpTrial {
  id                Int     @id @default(autoincrement())
  trialId           String
  sourceRegister    String
  publicTitle       String
  scientificTitle   String?
  primarySponsor    String?
  contactName       String
  contactNameLower  String
  recruitmentStatus String?
  registrationYear  Int?

  @@index([contactNameLower])
}
