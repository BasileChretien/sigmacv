# E2E test environment. Copy to `.env.e2e`. Uses an ISOLATED test database
# (note the `_e2e` name — global-setup refuses to run against anything else)
# and the dev server (NODE_ENV unset) to avoid production-only env assertions.
DATABASE_URL="postgresql://sigmacv:sigmacv@localhost:5433/sigmacv_e2e?schema=public"
AUTH_SECRET="e2e-dev-secret-e2e-dev-secret-1234"
AUTH_URL="http://localhost:3100"

# Dummy non-empty values so getEnv() passes; ORCID OAuth is bypassed by seeding
# the session directly, so these are never used to contact ORCID.
ORCID_CLIENT_ID="APP-E2E"
ORCID_CLIENT_SECRET="e2e-dummy-secret"
ORCID_ENVIRONMENT="sandbox"

OPENALEX_MAILTO="e2e@example.org"
# Points OpenAlex fetches at the local fixture server (see e2e/fixtures/openalex-server.ts).
OPENALEX_API_BASE="http://127.0.0.1:3201"
