# dependencies
/node_modules
/.pnp
.pnp.*

# next.js
/.next/
/out/
next-env.d.ts

# production
/build

# testing
/coverage

# CycloneDX SBOM (generated by `npm run sbom`; attached to GitHub releases, not committed)
*.cdx.json

# typescript build info
*.tsbuildinfo

# prisma
/prisma/*.db
# Generated Prisma 7 client (regenerated by `prisma generate`; never committed).
/src/generated/

# env files (never commit secrets)
.env
.env*.local
.env.development
.env.production
.env.e2e

# playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# stray local tool binaries (tunnels, CLIs) — these live outside the repo
*.exe

# local dev server log
/devserver.log
*.log

# misc
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.idea/
.vscode/*
!.vscode/extensions.json

# ensure-db schema-sync fingerprint (local)
.prisma-pushed

# Raw Open Editors Plus parquet (~68MB). NOT committed — the small, filtered,
# committed seed (prisma/seed-data/oep-editorial-roles.ndjson.gz) is derived from
# it via scripts/oep-build-seed.py. Keep the parquet here locally to rebuild.
/Open_editors_plus/

# IRB / ethics application materials (may contain personal data; not for the public repo)
/Ethics/
/docs/irb/

# Researcher data exports (pseudonymised human-subjects data — NEVER commit)
/research-export/

# Research paper drafts, study preregistration plans, and the namesake benchmark
# (kept local only — not for the public repo)
/docs/paper/
/docs/preregistration/
/scripts/benchmark-namesake-ambiguity.ts

# Throwaway QA / design-preview artifacts (per CLAUDE.md, never committed)
/.preview/

# Local Claude Code config (preview launch profile etc.)
/.claude/
